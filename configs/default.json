{
  "server": {
    "port": 3000
  },
  "storage": {
    "storiesDir": "stories",
    "chatsDir": "chats"
  },
  "llm": {
    "defaultModel": "x-ai/grok-4.20-beta",
    "temperature": 0.8,
    "maxTokens": 16384,
    "retry": {
      "maxRetries": 3,
      "baseDelayMs": 1000
    },
    "promptOptions": {
      "enableChainOfThought": true,
      "choiceGuidance": "strict"
    }
  },
  "logging": {
    "level": "debug",
    "prompts": {
      "enabled": true,
      "baseDir": "logs",
      "fileName": "prompts.jsonl"
    }
  }
}
