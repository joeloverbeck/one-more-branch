<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <%- include('../partials/header') %>

  <main class="container" id="concepts-page">
    <section class="form-section">
      <h1>Story Concepts</h1>

      <section id="concept-generate-section">
        <h2>Generate New Concepts</h2>
        <form id="concept-generate-form">
          <div class="form-group">
            <label for="kernel-selector">Story Kernel *</label>
            <select id="kernel-selector" required>
              <option value="">Select a saved kernel...</option>
            </select>
          </div>

          <article id="selected-kernel-summary" class="spine-card" style="display: none; margin-bottom: 1rem;">
            <h3 class="spine-cdq">Selected Kernel</h3>
            <p class="spine-field"><span class="spine-label">Dramatic Thesis:</span> <span id="selected-kernel-dramatic-thesis"></span></p>
            <p class="spine-field"><span class="spine-label">Value At Stake:</span> <span id="selected-kernel-value-at-stake"></span></p>
            <p class="spine-field"><span class="spine-label">Opposing Force:</span> <span id="selected-kernel-opposing-force"></span></p>
            <p class="spine-field"><span class="spine-label">Thematic Question:</span> <span id="selected-kernel-thematic-question"></span></p>
            <p class="spine-field"><span class="spine-label">Overall Score:</span> <span id="selected-kernel-overall-score"></span></p>
          </article>

          <div class="form-group">
            <label for="protagonistDetails">Protagonist Details *</label>
            <textarea
              id="protagonistDetails"
              required
              rows="3"
              placeholder="A disgraced former surgeon who lost her medical license after a botched operation, now working as a back-alley cybernetic installer..."
            ></textarea>
            <p class="form-help">
              Describe your protagonist — who they are, their background, defining traits. This will be treated as an absolute constraint during concept generation.
            </p>
          </div>

          <div class="form-group">
            <label for="genreVibes">Genre Vibes</label>
            <input
              type="text"
              id="genreVibes"
              placeholder="dark fantasy, sci-fi noir, cosmic horror..."
            >
          </div>

          <div class="form-group">
            <label for="moodKeywords">Mood Keywords</label>
            <input
              type="text"
              id="moodKeywords"
              placeholder="melancholic, tense, whimsical..."
            >
          </div>

          <div class="form-group">
            <label for="contentPreferences">Content Preferences</label>
            <input
              type="text"
              id="contentPreferences"
              placeholder="include body horror, no romance..."
            >
          </div>

          <div class="form-group">
            <label>Genre Exclusions <span class="genre-chip-counter" id="genre-chip-counter">(<%= genreFrames.length %> of <%= genreFrames.length %> available)</span></label>
            <p class="form-help">Click genres to exclude them from generation. At least 6 must remain.</p>
            <div class="genre-chip-grid" id="genre-chip-grid">
              <% genreFrames.forEach(function(genre) { %>
              <button type="button" class="genre-chip" data-genre="<%= genre %>"><%= genre.replace(/_/g, ' ') %></button>
              <% }); %>
            </div>
          </div>

          <div class="form-group">
            <label for="conceptApiKey">OpenRouter API Key *</label>
            <input
              type="password"
              id="conceptApiKey"
              required
              placeholder="sk-or-..."
              autocomplete="off"
            >
            <p class="form-help">
              Get your API key from <a href="https://openrouter.ai/keys" target="_blank" rel="noopener noreferrer">OpenRouter</a>.
              Your key is never stored on the server.
            </p>
          </div>

          <div class="form-actions">
            <button type="button" id="generate-concepts-btn" class="btn btn-primary btn-large" disabled>Generate Concepts</button>
          </div>
        </form>
      </section>

      <section id="concept-selection-section" style="display: none;">
        <h2 class="section-title">Review & Select Concepts</h2>
        <p class="spine-section-subtitle">Choose which concepts to develop further. Unselected concepts will be discarded.</p>
        <div class="concept-selection-controls">
          <button id="select-all-concepts-btn" type="button" class="btn btn-secondary btn-small">Select All</button>
          <button id="deselect-all-concepts-btn" type="button" class="btn btn-secondary btn-small">Deselect All</button>
          <span id="concept-selection-counter" class="concept-selection-counter"></span>
        </div>
        <div id="concept-selection-cards" class="spine-options-container"></div>
        <div class="form-actions">
          <button id="develop-concepts-btn" type="button" class="btn btn-primary" disabled>Continue with Selected</button>
        </div>
      </section>

      <section id="concept-results-section" class="spine-section" style="display: none;">
        <h2 class="spine-section-title">Generated Concepts</h2>
        <p class="spine-section-subtitle">Click "Save" on any concept to add it to your library.</p>
        <div id="concept-cards" class="spine-options-container"></div>
      </section>

      <section id="saved-concepts-section">
        <h2>Saved Concepts</h2>
        <% if (concepts.length === 0) { %>
          <p class="spine-section-subtitle">No saved concepts yet. Generate some above!</p>
        <% } %>
        <% const groupedConcepts = typeof genreGroups !== 'undefined' && Array.isArray(genreGroups) ? genreGroups : []; %>
        <div id="saved-concepts-list">
          <% for (const group of groupedConcepts) { %>
          <details class="genre-group" data-genre="<%= group.genre %>">
            <summary class="genre-group__header">
              <span class="genre-group__label"><%= group.displayLabel %></span>
              <span class="genre-group__count">(<%= group.concepts.length %>)</span>
            </summary>
            <% if (group.conventions.length > 0 || group.obligations.length > 0) { %>
            <div class="genre-info-panel">
              <div class="genre-info-panel__column">
                <h4 class="genre-info-panel__heading">Conventions</h4>
                <hr class="genre-info-panel__divider">
                <ul class="genre-info-panel__list">
                  <% for (const gloss of group.conventions) { %>
                  <li><%= gloss %></li>
                  <% } %>
                </ul>
              </div>
              <div class="genre-info-panel__column">
                <h4 class="genre-info-panel__heading">Obligations</h4>
                <hr class="genre-info-panel__divider">
                <ul class="genre-info-panel__list">
                  <% for (const gloss of group.obligations) { %>
                  <li><%= gloss %></li>
                  <% } %>
                </ul>
              </div>
            </div>
            <% } %>
            <div class="genre-group__body spine-options-container">
          <% for (const concept of group.concepts) { %>
          <% const cc = concept.evaluatedConcept.concept; %>
          <article class="spine-card concept-card saved-concept-card" data-concept-id="<%= concept.id %>">
            <div class="spine-badges">
              <span class="spine-badge spine-badge-type"><%= (cc.genreFrame || '').replace(/_/g, ' ') %></span>
              <span class="spine-badge spine-badge-conflict"><%= (cc.conflictAxis || '').replace(/_/g, ' ') %></span>
              <% if (cc.conflictType) { %><span class="spine-badge spine-badge-conflict"><%= cc.conflictType.replace(/_/g, ' ') %></span><% } %>
              <% if (cc.settingScale) { %><span class="spine-badge spine-badge-type"><%= cc.settingScale.replace(/_/g, ' ') %></span><% } %>
              <span class="spine-badge spine-badge-arc">Score <%= Math.round(concept.evaluatedConcept.overallScore || 0) %></span>
              <% if (concept.hardenedAt) { %>
              <span class="spine-badge spine-badge-type" style="background: var(--accent-green, #2ecc71);">Hardened</span>
              <% } %>
            </div>
            <h3 class="spine-cdq"><%= concept.name %></h3>
            <p class="spine-field"><%= cc.elevatorParagraph || '' %></p>
            <div class="spine-field"><span class="spine-label">Protagonist:</span> <%= cc.protagonistRole || '' %></div>
            <% if (cc.coreCompetence) { %><div class="spine-field"><span class="spine-label">Core Competence:</span> <%= cc.coreCompetence %></div><% } %>
            <% if (cc.coreFlaw) { %><div class="spine-field"><span class="spine-label">Core Flaw:</span> <%= cc.coreFlaw %></div><% } %>
            <% if (cc.coreConflictLoop) { %><div class="spine-field"><span class="spine-label">Conflict Loop:</span> <%= cc.coreConflictLoop %></div><% } %>
            <% if (cc.pressureSource) { %><div class="spine-field"><span class="spine-label">Pressure Source:</span> <%= cc.pressureSource %></div><% } %>
            <% if (cc.stakesPersonal) { %><div class="spine-field"><span class="spine-label">Personal Stakes:</span> <%= cc.stakesPersonal %></div><% } %>
            <% if (cc.stakesSystemic) { %><div class="spine-field"><span class="spine-label">Systemic Stakes:</span> <%= cc.stakesSystemic %></div><% } %>
            <% if (cc.deadlineMechanism) { %><div class="spine-field"><span class="spine-label">Deadline Mechanism:</span> <%= cc.deadlineMechanism %></div><% } %>
            <% if (cc.genreSubversion) { %><div class="spine-field"><span class="spine-label">Genre Subversion:</span> <%= cc.genreSubversion %></div><% } %>
            <% if (cc.whatIfQuestion) { %><p class="spine-field concept-what-if"><span class="spine-label">What If:</span> <em><%= cc.whatIfQuestion %></em></p><% } %>
            <% if (cc.ironicTwist) { %><div class="spine-field"><span class="spine-label">Ironic Twist:</span> <%= cc.ironicTwist %></div><% } %>
            <% if (cc.playerFantasy) { %><p class="spine-field"><span class="spine-label">Player Fantasy:</span> <em><%= cc.playerFantasy %></em></p><% } %>
            <% if (cc.incitingDisruption) { %><div class="spine-field"><span class="spine-label">Inciting Disruption:</span> <%= cc.incitingDisruption %></div><% } %>
            <% if (cc.escapeValve) { %><div class="spine-field"><span class="spine-label">Escape Valve:</span> <%= cc.escapeValve %></div><% } %>
            <% if (cc.protagonistLie) { %><div class="spine-field"><span class="spine-label">Protagonist Lie:</span> <%= cc.protagonistLie %></div><% } %>
            <% if (cc.protagonistTruth) { %><div class="spine-field"><span class="spine-label">Protagonist Truth:</span> <%= cc.protagonistTruth %></div><% } %>
            <% if (cc.protagonistGhost) { %><div class="spine-field"><span class="spine-label">Protagonist Ghost:</span> <%= cc.protagonistGhost %></div><% } %>
            <% if (cc.wantNeedCollisionSketch) { %><div class="spine-field"><span class="spine-label">Want/Need Collision:</span> <%= cc.wantNeedCollisionSketch %></div><% } %>
            <% if (Array.isArray(cc.actionVerbs) && cc.actionVerbs.length > 0) { %><div class="spine-field"><span class="spine-label">Action Verbs:</span> <%= cc.actionVerbs.join(', ') %></div><% } %>
            <% if (Array.isArray(cc.settingAxioms) && cc.settingAxioms.length > 0) { %><div class="spine-field"><span class="spine-label">Setting Axioms:</span><ul><% cc.settingAxioms.forEach(function(a) { %><li><%= a %></li><% }); %></ul></div><% } %>
            <% if (Array.isArray(cc.constraintSet) && cc.constraintSet.length > 0) { %><div class="spine-field"><span class="spine-label">Constraints:</span><ul><% cc.constraintSet.forEach(function(a) { %><li><%= a %></li><% }); %></ul></div><% } %>
            <% if (Array.isArray(cc.keyInstitutions) && cc.keyInstitutions.length > 0) { %><div class="spine-field"><span class="spine-label">Key Institutions:</span><ul><% cc.keyInstitutions.forEach(function(a) { %><li><%= a %></li><% }); %></ul></div><% } %>
            <%
              const ev = concept.evaluatedConcept;
              const scoreFields = [
                { key: 'hookStrength', label: 'Hook' },
                { key: 'conflictEngine', label: 'Conflict' },
                { key: 'agencyBreadth', label: 'Agency' },
                { key: 'noveltyLeverage', label: 'Novelty' },
                { key: 'llmFeasibility', label: 'Feasibility' },
                { key: 'ironicPremise', label: 'Irony' },
                { key: 'sceneGenerativePower', label: 'Scenes' },
              ];
              function getScoreColor(s) { if (s <= 2) return 'low'; if (s <= 3) return 'mid'; return 'high'; }
            %>
            <div class="concept-scores">
              <div class="concept-scores-grid">
                <% scoreFields.forEach(function(sf) {
                  const raw = Number(ev.scores && ev.scores[sf.key]);
                  const safe = Number.isFinite(raw) ? Math.max(0, Math.min(5, raw)) : 0;
                  const color = getScoreColor(safe);
                  const full = Math.floor(safe);
                  const hasHalf = (safe % 1) >= 0.25;
                %>
                <div class="concept-score-cell">
                  <span class="concept-score-label"><%= sf.label %></span>
                  <span class="concept-score-value concept-score-value--<%= color %>"><%= safe.toFixed(1) %></span>
                  <div class="concept-score-pips">
                    <% for (let i = 0; i < 5; i++) { %>
                      <% if (i < full) { %>
                        <span class="concept-pip concept-pip--filled concept-pip--<%= color %>"></span>
                      <% } else if (i === full && hasHalf) { %>
                        <span class="concept-pip concept-pip--half concept-pip--<%= color %>"></span>
                      <% } else { %>
                        <span class="concept-pip concept-pip--empty"></span>
                      <% } %>
                    <% } %>
                  </div>
                </div>
                <% }); %>
              </div>
            </div>
            <% if (ev.tradeoffSummary) { %><div class="spine-field"><span class="spine-label">Tradeoff:</span> <%= ev.tradeoffSummary %></div><% } %>
            <div class="concept-feedback">
              <div class="concept-feedback-block"><span class="spine-label">Strengths</span><ul><% if (Array.isArray(ev.strengths) && ev.strengths.length > 0) { ev.strengths.forEach(function(s) { %><li><%= s %></li><% }); } else { %><li class="concept-list-empty">None</li><% } %></ul></div>
              <div class="concept-feedback-block"><span class="spine-label">Weaknesses</span><ul><% if (Array.isArray(ev.weaknesses) && ev.weaknesses.length > 0) { ev.weaknesses.forEach(function(w) { %><li><%= w %></li><% }); } else { %><li class="concept-list-empty">None</li><% } %></ul></div>
            </div>
            <% if (concept.verificationResult) { %>
            <% const vr = concept.verificationResult; %>
            <div class="concept-verification-section" style="margin-top: 0.75rem; border-top: 1px solid var(--border-subtle, #333); padding-top: 0.75rem;">
              <div class="spine-label" style="margin-bottom: 0.5rem; font-weight: 600;">Verification</div>
              <% if (vr.signatureScenario) { %><div class="spine-field"><span class="spine-label">Signature Scenario:</span> <%= vr.signatureScenario %></div><% } %>
              <% if (vr.logline) { %>
              <div class="spine-field"><span class="spine-label">Logline:</span> <em><%= vr.logline %></em><% if (typeof vr.loglineCompressible === 'boolean') { %> <span class="spine-badge <%= vr.loglineCompressible ? 'spine-badge-pass' : 'spine-badge-fail' %>" style="font-size: 0.75rem;"><%= vr.loglineCompressible ? 'PASS' : 'FAIL' %></span><% } %></div>
              <% } %>
              <% if (vr.inevitabilityStatement) { %><div class="spine-field"><span class="spine-label">Inevitability:</span> <%= vr.inevitabilityStatement %></div><% } %>
              <% if (Array.isArray(vr.premisePromises) && vr.premisePromises.length > 0) { %>
              <div class="spine-field"><span class="spine-label">Premise Promises:</span>
                <ul style="margin: 0.25rem 0 0 1.25rem; padding: 0;"><% vr.premisePromises.forEach(function(pp) { %><li><%= pp %></li><% }); %></ul>
              </div>
              <% } %>
              <% if (Number.isFinite(Number(vr.conceptIntegrityScore))) { %><div class="spine-field"><span class="spine-label">Integrity Score:</span> <%= Math.max(0, Math.min(100, Math.round(Number(vr.conceptIntegrityScore)))) %>/100</div><% } %>
              <% if (Array.isArray(vr.escalatingSetpieces) && vr.escalatingSetpieces.length > 0) { %>
              <div class="spine-field"><span class="spine-label">Escalating Setpieces:</span>
                <ol style="margin: 0.25rem 0 0 1.25rem; padding: 0;"><% vr.escalatingSetpieces.forEach(function(sp) { %><li><%= sp %></li><% }); %></ol>
              </div>
              <% } %>
              <% if (Array.isArray(vr.setpieceCausalLinks) && vr.setpieceCausalLinks.length > 0) { %>
              <div class="spine-field"><span class="spine-label">Causal Links:</span><% if (typeof vr.setpieceCausalChainBroken === 'boolean') { %> <span class="spine-badge <%= vr.setpieceCausalChainBroken ? 'spine-badge-fail' : 'spine-badge-pass' %>" style="font-size: 0.75rem;"><%= vr.setpieceCausalChainBroken ? 'BROKEN' : 'PASS' %></span><% } %>
                <ol style="margin: 0.25rem 0 0 1.25rem; padding: 0;"><% vr.setpieceCausalLinks.forEach(function(link) { %><li><%= link %></li><% }); %></ol>
              </div>
              <% } %>
              <% if (vr.loadBearingCheck && typeof vr.loadBearingCheck === 'object') { %>
              <% const lbc = vr.loadBearingCheck; %>
              <div class="spine-field"><span class="spine-label">Load-Bearing Check:</span> <% if (typeof lbc.passes === 'boolean') { %><span class="spine-badge <%= lbc.passes ? 'spine-badge-pass' : 'spine-badge-fail' %>" style="font-size: 0.75rem;"><%= lbc.passes ? 'PASS' : 'GENERIC RISK' %></span><% } %></div>
              <% if (lbc.reasoning) { %><div class="spine-field" style="margin-left: 0.5rem;"><span class="spine-label">Reasoning:</span> <%= lbc.reasoning %></div><% } %>
              <% if (lbc.genericCollapse) { %><div class="spine-field" style="margin-left: 0.5rem;"><span class="spine-label">Generic Collapse:</span> <%= lbc.genericCollapse %></div><% } %>
              <% } %>
              <% if (vr.kernelFidelityCheck && typeof vr.kernelFidelityCheck === 'object') { %>
              <% const kfc = vr.kernelFidelityCheck; %>
              <div class="spine-field"><span class="spine-label">Kernel Fidelity Check:</span> <% if (typeof kfc.passes === 'boolean') { %><span class="spine-badge <%= kfc.passes ? 'spine-badge-pass' : 'spine-badge-fail' %>" style="font-size: 0.75rem;"><%= kfc.passes ? 'PASS' : 'FAIL' %></span><% } %></div>
              <% if (kfc.reasoning) { %><div class="spine-field" style="margin-left: 0.5rem;"><span class="spine-label">Reasoning:</span> <%= kfc.reasoning %></div><% } %>
              <% if (kfc.kernelDrift) { %><div class="spine-field" style="margin-left: 0.5rem;"><span class="spine-label">Kernel Drift:</span> <%= kfc.kernelDrift %></div><% } %>
              <% } %>
            </div>
            <% } %>
            <% if (concept.stressTestResult && (Array.isArray(concept.stressTestResult.driftRisks) && concept.stressTestResult.driftRisks.length > 0 || Array.isArray(concept.stressTestResult.playerBreaks) && concept.stressTestResult.playerBreaks.length > 0)) { %>
            <% const str = concept.stressTestResult; %>
            <div class="concept-verification-section" style="margin-top: 0.75rem; border-top: 1px solid var(--border-subtle, #333); padding-top: 0.75rem;">
              <div class="spine-label" style="margin-bottom: 0.5rem; font-weight: 600;">Stress Test Results</div>
              <% if (Array.isArray(str.driftRisks) && str.driftRisks.length > 0) { %>
              <div class="spine-field"><span class="spine-label">Drift Risks:</span></div>
              <% str.driftRisks.forEach(function(dr) { %>
              <div class="spine-field" style="margin-left: 0.5rem; margin-bottom: 0.5rem;">
                <div><span class="spine-label">Risk:</span> <%= dr.risk || '' %></div>
                <div><span class="spine-label">Mitigation:</span> <%= dr.mitigation || '' %><% if (dr.mitigationType) { %> <span class="spine-badge spine-badge-type" style="font-size: 0.75rem;"><%= (dr.mitigationType || '').replace(/_/g, ' ') %></span><% } %></div>
              </div>
              <% }); %>
              <% } %>
              <% if (Array.isArray(str.playerBreaks) && str.playerBreaks.length > 0) { %>
              <div class="spine-field"><span class="spine-label">Player Breaks:</span></div>
              <% str.playerBreaks.forEach(function(pb) { %>
              <div class="spine-field" style="margin-left: 0.5rem; margin-bottom: 0.5rem;">
                <div><span class="spine-label">Scenario:</span> <%= pb.scenario || '' %></div>
                <div><span class="spine-label">Handling:</span> <%= pb.handling || '' %></div>
                <div><span class="spine-label">Constraint Used:</span> <%= pb.constraintUsed || '' %></div>
              </div>
              <% }); %>
              <% } %>
            </div>
            <% } %>
            <div class="spine-field">
              <span class="spine-label">Created:</span> <%= new Date(concept.createdAt).toLocaleDateString() %>
              <% if (concept.updatedAt !== concept.createdAt) { %>
                | <span class="spine-label">Updated:</span> <%= new Date(concept.updatedAt).toLocaleDateString() %>
              <% } %>
            </div>
            <div class="form-actions" style="margin-top: 0.5rem;">
              <button type="button" class="btn btn-secondary btn-small concept-edit-btn" data-concept-id="<%= concept.id %>">Edit</button>
              <button type="button" class="btn btn-primary btn-small concept-harden-btn" data-concept-id="<%= concept.id %>" <%= concept.hardenedAt ? 'disabled' : '' %>><%= concept.hardenedAt ? 'Already Hardened' : 'Harden' %></button>
              <button type="button" class="btn btn-danger btn-small concept-delete-btn" data-concept-id="<%= concept.id %>">Delete</button>
            </div>
          </article>
          <% } %>
            </div>
          </details>
          <% } %>
        </div>
      </section>
    </section>

    <div id="concept-edit-modal" class="loading-overlay" style="display: none;">
      <div class="form-section" style="max-width: 700px; max-height: 90vh; overflow-y: auto; position: relative;">
        <button type="button" id="concept-edit-close" class="btn btn-secondary btn-small" style="position: absolute; top: 1rem; right: 1rem;">&times;</button>
        <h2>Edit Concept</h2>
        <div class="form-group">
          <label for="edit-name">Display Name</label>
          <input type="text" id="edit-name">
        </div>
        <div class="form-group">
          <label for="edit-oneLineHook">One-Line Hook</label>
          <input type="text" id="edit-oneLineHook">
        </div>
        <div class="form-group">
          <label for="edit-elevatorParagraph">Elevator Paragraph</label>
          <textarea id="edit-elevatorParagraph" rows="3"></textarea>
        </div>
        <div class="form-group">
          <label for="edit-protagonistRole">Protagonist Role</label>
          <input type="text" id="edit-protagonistRole">
        </div>
        <div class="form-group">
          <label for="edit-coreCompetence">Core Competence</label>
          <input type="text" id="edit-coreCompetence">
        </div>
        <div class="form-group">
          <label for="edit-coreFlaw">Core Flaw</label>
          <input type="text" id="edit-coreFlaw">
        </div>
        <div class="form-group">
          <label for="edit-coreConflictLoop">Core Conflict Loop</label>
          <textarea id="edit-coreConflictLoop" rows="2"></textarea>
        </div>
        <div class="form-group">
          <label for="edit-pressureSource">Pressure Source</label>
          <input type="text" id="edit-pressureSource">
        </div>
        <div class="form-group">
          <label for="edit-stakesPersonal">Personal Stakes</label>
          <input type="text" id="edit-stakesPersonal">
        </div>
        <div class="form-group">
          <label for="edit-stakesSystemic">Systemic Stakes</label>
          <input type="text" id="edit-stakesSystemic">
        </div>
        <div class="form-group">
          <label for="edit-deadlineMechanism">Deadline Mechanism</label>
          <input type="text" id="edit-deadlineMechanism">
        </div>
        <div class="form-group">
          <label for="edit-incitingDisruption">Inciting Disruption</label>
          <textarea id="edit-incitingDisruption" rows="2"></textarea>
        </div>
        <div class="form-group">
          <label for="edit-escapeValve">Escape Valve</label>
          <textarea id="edit-escapeValve" rows="2"></textarea>
