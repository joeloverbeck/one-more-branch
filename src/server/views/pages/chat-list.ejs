<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <%- include('../partials/header') %>

  <main class="container" id="chat-list-page">
    <section class="hero">
      <h1>Character Chats</h1>
      <p class="tagline">Resume saved conversations or set up a new in-character exchange.</p>
    </section>

    <section class="form-section" data-chat-list>
      <div class="story-card">
        <div class="story-card-content">
          <h2>Saved Chats</h2>
          <p class="form-help">Pick up a conversation where it left off or remove finished sessions.</p>

          <% if (!Array.isArray(chats) || chats.length === 0) { %>
            <p id="chat-list-empty-state">No chats yet. Start one from the new chat setup page.</p>
          <% } else { %>
            <div id="chat-list-items">
              <% chats.forEach(function(chat) { %>
                <article class="story-card" data-chat-summary data-chat-id="<%= chat.id %>">
                  <div class="story-card-content">
                    <h3>
                      <a href="/chat/<%= chat.id %>"><%= chat.targetCharacterName %> and <%= chat.interlocutorCharacterName %></a>
                    </h3>
                    <p><strong>Turns:</strong> <%= chat.turnCount %></p>
                    <p><strong>Location:</strong> <%= chat.location %></p>
                    <p>
                      <strong>Updated:</strong>
                      <time datetime="<%= chat.updatedAt %>"><%= new Date(chat.updatedAt).toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short', timeZone: 'UTC' }) %> UTC</time>
                    </p>
                  </div>
                  <div class="story-card-actions">
                    <a class="btn btn-secondary" href="/chat/<%= chat.id %>">Open Chat</a>
                    <button
                      type="button"
                      class="btn btn-danger"
                      data-chat-delete-button
                      data-chat-id="<%= chat.id %>"
                      data-chat-label="<%= chat.targetCharacterName %> and <%= chat.interlocutorCharacterName %>"
                    >
                      Delete
                    </button>
                  </div>
                </article>
              <% }); %>
            </div>
          <% } %>
        </div>
        <div class="story-card-actions">
          <a class="btn btn-primary" href="/chat/new">New Chat</a>
        </div>
      </div>
    </section>
  </main>

  <%- include('../partials/footer') %>

  <script src="/js/app.js"></script>
</body>
</html>
