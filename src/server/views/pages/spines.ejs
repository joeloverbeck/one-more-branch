<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <%- include('../partials/header') %>

  <main class="container" id="spines-page">
    <section class="form-section">
      <h1>Story Spines</h1>
      <p class="spine-section-subtitle">
        Generate structural spines that define the dramatic arc, conflict axis, and character trajectory for a story.
      </p>

      <section id="spine-generate-section">
        <h2>Generate New Spines</h2>
        <form id="spine-generate-form">
          <div class="form-group">
            <label for="spineConceptId">Concept *</label>
            <select id="spineConceptId" required>
              <option value="">Select a concept...</option>
              <% concepts.forEach(function(c) { %>
                <option value="<%= c.id %>"><%= c.name %></option>
              <% }); %>
            </select>
          </div>

          <div class="form-group">
            <label for="spineProtagonistId">Protagonist *</label>
            <select id="spineProtagonistId" required>
              <option value="">Select protagonist...</option>
              <% characters.forEach(function(ch) { %>
                <option value="<%= ch.id %>"><%= ch.name %></option>
              <% }); %>
            </select>
          </div>

          <div class="form-group">
            <label for="spineNpcIds">NPCs (optional, hold Ctrl to multi-select)</label>
            <select id="spineNpcIds" multiple>
              <% characters.forEach(function(ch) { %>
                <option value="<%= ch.id %>"><%= ch.name %></option>
              <% }); %>
            </select>
          </div>

          <div class="form-group">
            <label for="spineWorldbuildingId">Worldbuilding *</label>
            <select id="spineWorldbuildingId" required>
              <option value="">Select worldbuilding...</option>
              <% worldbuildings.forEach(function(w) { %>
                <option value="<%= w.id %>"><%= w.name %></option>
              <% }); %>
            </select>
          </div>

          <div class="form-group">
            <label for="spineTone">Tone</label>
            <textarea
              id="spineTone"
              rows="2"
              placeholder="e.g., dark fantasy, psychological horror, noir"
            ></textarea>
          </div>

          <div class="form-group">
            <label for="spineStartingSituation">Starting Situation</label>
            <textarea
              id="spineStartingSituation"
              rows="3"
              placeholder="Optional: describe the opening scenario"
            ></textarea>
          </div>

          <div class="form-group">
            <label for="spineApiKey">OpenRouter API Key *</label>
            <input
              type="password"
              id="spineApiKey"
              required
              placeholder="sk-or-..."
              autocomplete="off"
            >
            <p class="form-help">
              Get your API key from <a href="https://openrouter.ai/keys" target="_blank" rel="noopener noreferrer">OpenRouter</a>.
              Your key is never stored on the server.
            </p>
          </div>

          <div class="form-actions">
            <button
              type="button"
              id="generate-spines-btn"
              class="btn btn-primary btn-large"
              disabled
            >
              Generate Spines
            </button>
          </div>
        </form>
      </section>

      <section id="spine-progress-section" class="loading-overlay" style="display: none;">
        <div id="spine-progress-content" class="loading-overlay-content"></div>
      </section>

      <section id="generated-spines-section" class="spine-section" style="display: none;">
        <h2 class="spine-section-title">Generated Spine Options</h2>
        <p class="spine-section-subtitle">Click "Save" on any spine you want to keep.</p>
        <div id="generated-spines" class="spine-options-container"></div>
      </section>

      <section id="saved-spines-section">
        <h2>Saved Spines</h2>
        <div id="saved-spines">
          <% if (savedSpines.length === 0) { %>
            <p class="spine-section-subtitle">No saved spines yet. Generate some above!</p>
          <% } %>
        </div>
      </section>
    </section>
  </main>

  <%- include('../partials/footer') %>

  <script src="/js/app.js"></script>
</body>
</html>
