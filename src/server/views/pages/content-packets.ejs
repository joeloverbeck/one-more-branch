<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <%- include('../partials/header') %>

  <main class="container" id="content-packets-page">
    <section class="form-section">
      <h1>Content Packets</h1>

      <section id="content-generate-section">
        <h2>Generate Content Packets</h2>
        <form id="content-generate-form">
          <div class="form-group">
            <label>Exemplar Ideas *</label>
            <div id="exemplar-entries"></div>
            <div class="exemplar-add-form">
              <input type="text" id="exemplar-idea-input" placeholder="Describe an imaginative idea...">
              <button type="button" id="exemplar-add-btn" class="btn btn-secondary btn-small">Add</button>
            </div>
            <p class="form-help">
              Add imaginative ideas that represent your creative taste.
            </p>
          </div>

          <div class="form-group">
            <label for="contentMoodKeywords">Mood / Genre Keywords</label>
            <input
              type="text"
              id="contentMoodKeywords"
              placeholder="dark comedy, body horror, social satire..."
            >
          </div>

          <div class="form-group">
            <label for="contentPreferences">Content Preferences</label>
            <textarea
              id="contentPreferences"
              rows="2"
              placeholder="Optional preferences for the kind of content you want..."
            ></textarea>
          </div>

          <div class="form-group">
            <label class="checkbox-label">
              <input type="checkbox" id="usePipeline">
              Use full pipeline (taste distiller + sparkstormer + packeter + evaluator)
            </label>
          </div>

          <div class="form-group">
            <label for="contentApiKey">OpenRouter API Key *</label>
            <input type="password" id="contentApiKey" required placeholder="sk-or-..." autocomplete="off">
          </div>

          <button type="submit" class="btn btn-primary" id="content-generate-btn">
            Generate Content Packets
          </button>
        </form>

        <div class="loading-overlay" id="content-generation-progress" style="display: none;">
          <div class="loading-stage" aria-live="polite"></div>
          <div class="loading-spinner"></div>
          <p class="loading-status">Generating content packets...</p>
        </div>

        <div id="content-generation-results" style="display: none;">
          <h3>Generated Packets</h3>
          <div id="generated-packets-list"></div>
        </div>
      </section>

      <section id="saved-packets-section">
        <h2>Saved Packets</h2>
        <% if (!hasSavedPackets) { %>
          <p class="empty-state">No saved content packets yet. Generate some above.</p>
        <% } else { %>
          <div id="saved-packets-grid">
            <% contentKindGroups.forEach(group => { %>
              <details class="genre-group" data-genre="<%= group.kind %>">
                <summary class="genre-group__header">
                  <span class="genre-group__label"><%= group.displayLabel %></span>
                  <span class="genre-group__count">(<%= group.cards.length %>)</span>
                </summary>
                <div class="genre-group__body packets-grid">
                  <% group.cards.forEach(card => { %>
                    <article class="story-card" data-packet-id="<%= card.id %>">
                      <div class="story-card-content">
                        <div class="story-card-actions">
                          <% if (card.pinned) { %>
                            <span class="pin-badge" title="Pinned">&#128204;</span>
                          <% } %>
                        </div>
                        <dl class="story-details">
                          <% card.details.forEach(detail => { %>
                            <div class="story-detail-row" data-detail-key="<%= detail.key %>">
                              <dt><%= detail.label %></dt>
                              <dd>
                                <% if (Array.isArray(detail.value)) { %>
                                  <ul class="story-detail-list">
                                    <% detail.value.forEach(item => { %>
                                      <li><%= item %></li>
                                    <% }); %>
                                  </ul>
                                <% } else { %>
                                  <%= detail.value %>
                                <% } %>
                              </dd>
                            </div>
                          <% }); %>
                          <% card.metaDetails.forEach(detail => { %>
                            <div class="story-detail-row story-detail-row--meta" data-detail-key="<%= detail.key %>">
                              <dt><%= detail.label %></dt>
                              <dd><%= detail.value %></dd>
                            </div>
                          <% }); %>
                        </dl>
                        <div class="story-card-actions">
                          <button class="btn btn-sm pin-packet-btn" data-id="<%= card.id %>">
                            <%= card.pinned ? 'Unpin' : 'Pin' %>
                          </button>
                          <button class="btn btn-sm btn-danger delete-packet-btn" data-id="<%= card.id %>">
                            Delete
                          </button>
                        </div>
                      </div>
                    </article>
                  <% }); %>
                </div>
              </details>
            <% }); %>
          </div>
        <% } %>
      </section>
    </section>
  </main>

  <script src="/js/app.js"></script>
</body>
</html>
