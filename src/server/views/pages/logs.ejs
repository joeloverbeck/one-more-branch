<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <%- include('../partials/header') %>

  <main class="container">
    <section class="logs-section">
      <h1>Prompt Logs</h1>
      <p class="logs-date"><%= dateDisplay %></p>

      <% if (entries.length === 0) { %>
      <div class="empty-state">
        <p>No logs recorded today.</p>
      </div>
      <% } else { %>
      <p class="logs-count"><%= entries.length %> log entries</p>

      <% 
      function classifyLogEntry(entry) {
        const systemContent = entry.messages && entry.messages[0] && typeof entry.messages[0].content === 'string'
          ? entry.messages[0].content
          : '';
        const userContent = entry.messages && entry.messages[1] && typeof entry.messages[1].content === 'string'
          ? entry.messages[1].content
          : '';

        if (entry.promptType === 'kernelEvaluator') {
          const isDeep = systemContent.includes('DEEP EVALUATION RULES') ||
            userContent.includes('Deep-evaluate this full kernel set selected in code');
          if (isDeep) {
            return {
              typeClass: 'kernel-evaluator-deep',
              label: 'kernelEvaluator (Deep Evaluation)',
            };
          }
          return {
            typeClass: 'kernel-evaluator-scoring',
            label: 'kernelEvaluator (Scoring)',
          };
        }

        return {
          typeClass: entry.promptType,
          label: entry.promptType,
        };
      }
      %>

      <% entries.forEach((entry, i) => { %>
      <% const logDisplay = classifyLogEntry(entry); %>
      <details class="log-entry log-type-<%= logDisplay.typeClass %>">
        <summary>
          <strong><%= logDisplay.label %></strong>
          <span class="log-meta">
            <%= new Date(entry.timestamp).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', second: '2-digit' }) %>
            &middot; <%= entry.messageCount %> messages
          </span>
        </summary>
        <div class="log-entry-body">
          <% entry.messages.forEach((msg, j) => { %>
          <details class="log-message">
            <summary>
              <span class="log-role"><%= msg.role %></span>
              <span class="log-meta"><%= msg.content.length.toLocaleString() %> chars</span>
            </summary>
            <pre class="log-content"><%= msg.content %></pre>
          </details>
          <% }) %>
        </div>
      </details>
      <% }) %>
      <% } %>
    </section>
  </main>

  <%- include('../partials/footer') %>
</body>
</html>
