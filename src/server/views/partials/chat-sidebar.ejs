<aside class="chat-sidebar" id="chat-sidebar">
  <div class="chat-sidebar__section">
    <h2>Scene State</h2>
  </div>

  <details
    class="chat-accordion chat-sidebar__section"
    id="chat-physical-context"
    data-chat-section="physical"
    open
  >
    <summary class="chat-accordion-summary">
      <span class="chat-accordion-summary__title">Physical Context</span>
      <span class="chat-accordion-summary__meta">
        <span class="chat-summary-chip" data-chat-field="microLocation"><%= session.physicalContext.microLocation %></span>
        <span class="chat-summary-chip" data-chat-field="timeOfDay"><%= session.physicalContext.timeOfDay %></span>
        <span class="chat-summary-chip chat-summary-chip--accent" data-chat-field="distanceBand"><%= session.physicalContext.distanceBand %></span>
      </span>
    </summary>

    <div class="chat-accordion-content">
      <dl class="chat-sidebar-details">
        <div class="chat-sidebar-details__row">
          <dt>Location</dt>
          <dd><span data-chat-field="location"><%= session.physicalContext.location %></span></dd>
        </div>
        <div class="chat-sidebar-details__row">
          <dt>Micro-Location</dt>
          <dd><span data-chat-field="microLocation"><%= session.physicalContext.microLocation %></span></dd>
        </div>
        <div class="chat-sidebar-details__row">
          <dt>Time</dt>
          <dd><span data-chat-field="timeOfDay"><%= session.physicalContext.timeOfDay %></span></dd>
        </div>
        <div class="chat-sidebar-details__row">
          <dt>Privacy</dt>
          <dd><span data-chat-field="privacy"><%= session.physicalContext.privacy %></span></dd>
        </div>
        <div class="chat-sidebar-details__row">
          <dt>Distance</dt>
          <dd><span data-chat-field="distanceBand"><%= session.physicalContext.distanceBand %></span></dd>
        </div>
        <div class="chat-sidebar-details__row">
          <dt>Activity</dt>
          <dd><span data-chat-field="characterActivity"><%= session.physicalContext.characterActivity %></span></dd>
        </div>
        <div class="chat-sidebar-details__row chat-sidebar-details__row--stacked">
          <dt>Objects</dt>
          <dd>
            <span class="sr-only" data-chat-field="interactableObjects"><%= session.physicalContext.interactableObjects.join(', ') || 'None' %></span>
            <div class="chat-pill-row" data-chat-list="interactableObjects"></div>
          </dd>
        </div>
        <div class="chat-sidebar-details__row chat-sidebar-details__row--stacked">
          <dt>Conditions</dt>
          <dd>
            <span class="sr-only" data-chat-field="ambientConditions"><%= session.physicalContext.ambientConditions.join(', ') || 'None' %></span>
            <ul class="chat-sidebar-list" data-chat-list="ambientConditions"></ul>
          </dd>
        </div>
      </dl>
    </div>
  </details>

  <details
    class="chat-accordion chat-sidebar__section"
    id="chat-relationship-state"
    data-chat-section="relationship"
    open
  >
    <summary class="chat-accordion-summary">
      <span class="chat-accordion-summary__title">Relationship</span>
      <span class="chat-accordion-summary__meta">
        <span class="chat-summary-stat">V: <span data-chat-field="valence"><%= bootstrapRelationshipPresentation.valence.value %></span></span>
        <span class="chat-summary-stat">T: <span data-chat-field="tension"><%= bootstrapRelationshipPresentation.tension.value %></span></span>
      </span>
    </summary>

    <div class="chat-accordion-content">
      <div class="chat-relationship-visuals">
        <section class="chat-metric-card">
          <div class="chat-metric-card__header">
            <div>
              <h3>Valence</h3>
              <p class="chat-metric-card__summary" data-chat-gauge-summary="valence"><%= bootstrapRelationshipPresentation.valence.summary %></p>
            </div>
            <div class="chat-metric-card__meta">
              <span class="chat-metric-card__value" data-chat-gauge-value="valence"><%= bootstrapRelationshipPresentation.valence.value %></span>
              <span class="chat-metric-card__delta" data-chat-gauge-delta="valence"><%= formatSignedInnerWorldNumber(bootstrapRelationshipPresentation.valence.delta) %></span>
              <span class="chat-metric-card__trend" data-chat-gauge-trend="valence"><%= bootstrapRelationshipPresentation.valence.trend %></span>
            </div>
          </div>
          <div
            class="chat-gauge chat-gauge--valence"
            data-chat-gauge="valence"
            role="meter"
            aria-label="<%= bootstrapRelationshipPresentation.valence.gaugeAriaLabel %>"
          >
            <span class="chat-gauge__track"></span>
            <span class="chat-gauge__ghost"></span>
            <span class="chat-gauge__marker"></span>
          </div>
          <div class="chat-gauge__anchors" aria-hidden="true">
            <span>Hostile</span>
            <span>Neutral</span>
            <span>Loyal</span>
          </div>
          <svg
            class="chat-sparkline"
            data-chat-sparkline="valence"
            viewBox="0 0 120 32"
            role="img"
            aria-label="<%= bootstrapRelationshipPresentation.valence.sparklineAriaLabel %>"
          ></svg>
        </section>

        <section class="chat-metric-card">
          <div class="chat-metric-card__header">
            <div>
              <h3>Tension</h3>
              <p class="chat-metric-card__summary" data-chat-gauge-summary="tension"><%= bootstrapRelationshipPresentation.tension.summary %></p>
            </div>
            <div class="chat-metric-card__meta">
              <span class="chat-metric-card__value" data-chat-gauge-value="tension"><%= bootstrapRelationshipPresentation.tension.value %></span>
              <span class="chat-metric-card__delta" data-chat-gauge-delta="tension"><%= formatSignedInnerWorldNumber(bootstrapRelationshipPresentation.tension.delta) %></span>
              <span class="chat-metric-card__trend" data-chat-gauge-trend="tension"><%= bootstrapRelationshipPresentation.tension.trend %></span>
            </div>
          </div>
          <div
            class="chat-gauge chat-gauge--tension"
            data-chat-gauge="tension"
            role="meter"
            aria-label="<%= bootstrapRelationshipPresentation.tension.gaugeAriaLabel %>"
          >
            <span class="chat-gauge__track"></span>
            <span class="chat-gauge__ghost"></span>
            <span class="chat-gauge__marker"></span>
          </div>
          <div class="chat-gauge__anchors" aria-hidden="true">
            <span>Calm</span>
            <span>Strained</span>
            <span>Breaking</span>
          </div>
          <svg
            class="chat-sparkline"
            data-chat-sparkline="tension"
            viewBox="0 0 120 32"
            role="img"
            aria-label="<%= bootstrapRelationshipPresentation.tension.sparklineAriaLabel %>"
          ></svg>
        </section>
      </div>

      <dl class="chat-sidebar-details chat-sidebar-details--compact">
        <div class="chat-sidebar-details__row">
          <dt>Dynamic</dt>
          <dd><span data-chat-field="dynamic"><%= (bootstrapRelationshipSnapshot?.dynamic || session.relationshipState.dynamic) || 'Unformed' %></span></dd>
        </div>
        <div class="chat-sidebar-details__row">
          <dt>Leverage</dt>
          <dd><span data-chat-field="leverage"><%= (bootstrapRelationshipSnapshot?.leverage || session.relationshipState.leverage) || 'None' %></span></dd>
        </div>
      </dl>
    </div>
  </details>

  <details
    class="chat-accordion chat-sidebar__section"
    id="chat-knowledge-state"
    data-chat-section="knowledge"
    open
  >
    <summary class="chat-accordion-summary">
      <span class="chat-accordion-summary__title">Knowledge State</span>
      <span class="chat-accordion-summary__meta">
        <span class="chat-summary-chip" data-chat-field="knowledgeSummary"><%= knowledgeSummary %></span>
      </span>
    </summary>

    <div class="chat-accordion-content">
      <section class="chat-sidebar-group">
        <h3>Known Facts</h3>
        <ul class="chat-sidebar-list" data-chat-list="knownFacts">
          <% if (sanitizeSidebarItems(bootstrapKnowledgeState.knownFacts).length === 0) { %>
            <li class="chat-sidebar-list__empty">No facts tracked.</li>
          <% } else { %>
            <% sanitizeSidebarItems(bootstrapKnowledgeState.knownFacts).forEach(function(item) { %>
              <li><%= item %></li>
            <% }); %>
          <% } %>
        </ul>
      </section>

      <section class="chat-sidebar-group">
        <h3>Suspicions</h3>
        <ul class="chat-sidebar-list chat-list--italic" data-chat-list="suspicions">
          <% if (sanitizeSidebarItems(bootstrapKnowledgeState.suspicions).length === 0) { %>
            <li class="chat-sidebar-list__empty">No suspicions tracked.</li>
          <% } else { %>
            <% sanitizeSidebarItems(bootstrapKnowledgeState.suspicions).forEach(function(item) { %>
              <li><%= item %></li>
            <% }); %>
          <% } %>
        </ul>
      </section>

      <section class="chat-sidebar-group">
        <h3>False Beliefs</h3>
        <ul class="chat-sidebar-list chat-list--warning" data-chat-list="falseBeliefs">
          <% if (sanitizeSidebarItems(bootstrapKnowledgeState.falseBeliefs).length === 0) { %>
            <li class="chat-sidebar-list__empty">No false beliefs tracked.</li>
          <% } else { %>
            <% sanitizeSidebarItems(bootstrapKnowledgeState.falseBeliefs).forEach(function(item) { %>
              <li><%= item %></li>
            <% }); %>
          <% } %>
        </ul>
      </section>

      <section class="chat-sidebar-group">
        <h3>Secrets Revealed</h3>
        <ul class="chat-sidebar-list" data-chat-list="secretsRevealed">
          <% if (sanitizeSidebarItems(bootstrapKnowledgeState.secretsRevealed).length === 0) { %>
            <li class="chat-sidebar-list__empty">No secrets revealed.</li>
          <% } else { %>
            <% sanitizeSidebarItems(bootstrapKnowledgeState.secretsRevealed).forEach(function(item) { %>
              <li><%= item %></li>
            <% }); %>
          <% } %>
        </ul>
      </section>
    </div>
  </details>

  <details
    class="chat-accordion chat-sidebar__section"
    id="chat-character-mind"
    data-chat-section="mind"
    open
  >
    <summary class="chat-accordion-summary">
      <span class="chat-accordion-summary__title">Character Mind</span>
      <span class="chat-accordion-summary__meta">
        <span class="chat-summary-chip" data-chat-field="currentObjectiveSummary"><%= currentObjectiveSummary %></span>
      </span>
    </summary>

    <div class="chat-accordion-content">
      <dl class="chat-sidebar-details chat-sidebar-details--compact">
        <div class="chat-sidebar-details__row">
          <dt>Current Objective</dt>
          <dd><span data-chat-field="currentObjective"><%= normalizeSidebarText(bootstrapChatBible?.characterNow?.currentObjective, 'No current objective available.') %></span></dd>
        </div>
        <div class="chat-sidebar-details__row">
          <dt>Immediate Need</dt>
          <dd><span data-chat-field="immediateNeedFromConversation"><%= normalizeSidebarText(bootstrapChatBible?.characterNow?.immediateNeedFromConversation, 'No immediate need available.') %></span></dd>
        </div>
        <div class="chat-sidebar-details__row">
          <dt>Emotional State</dt>
          <dd><span data-chat-field="emotionalState"><%= normalizeSidebarText(bootstrapChatBible?.characterNow?.emotionalState, 'No emotional state available.') %></span></dd>
        </div>
        <div class="chat-sidebar-details__row">
          <dt>Willingness</dt>
          <dd>
            <span class="chat-pill chat-pill--badge" data-chat-field="willingnessToEngage"><%= normalizeSidebarText(bootstrapChatBible?.characterNow?.willingnessToEngage, 'Unknown') %></span>
          </dd>
        </div>
      </dl>

      <section class="chat-sidebar-group">
        <h3>Topics to Advance</h3>
        <ul class="chat-sidebar-list" data-chat-list="topicsToAdvance">
          <% if (sanitizeSidebarItems(bootstrapChatBible?.characterNow?.topicsToAdvance).length === 0) { %>
            <li class="chat-sidebar-list__empty">No active advance topics.</li>
          <% } else { %>
            <% sanitizeSidebarItems(bootstrapChatBible?.characterNow?.topicsToAdvance).forEach(function(item) { %>
              <li><%= item %></li>
            <% }); %>
          <% } %>
        </ul>
      </section>

      <section class="chat-sidebar-group">
        <h3>Topics to Protect</h3>
        <ul class="chat-sidebar-list chat-sidebar-list--prefixed" data-chat-list="topicsToProtect">
          <% if (sanitizeSidebarItems(bootstrapChatBible?.characterNow?.topicsToProtect).length === 0) { %>
            <li class="chat-sidebar-list__empty">No protected topics.</li>
          <% } else { %>
            <% sanitizeSidebarItems(bootstrapChatBible?.characterNow?.topicsToProtect).forEach(function(item) { %>
              <li><span class="chat-list-prefix" aria-hidden="true">Lock</span><span><%= item %></span></li>
            <% }); %>
          <% } %>
        </ul>
      </section>

      <section class="chat-sidebar-group">
        <h3>Beliefs About Interlocutor</h3>
        <ul class="chat-sidebar-list" data-chat-list="beliefsAboutInterlocutor">
          <% if (sanitizeSidebarItems(bootstrapRelationshipSnapshot?.whatCharacterBelievesAboutInterlocutor).length === 0) { %>
            <li class="chat-sidebar-list__empty">No beliefs recorded.</li>
          <% } else { %>
            <% sanitizeSidebarItems(bootstrapRelationshipSnapshot?.whatCharacterBelievesAboutInterlocutor).forEach(function(item) { %>
              <li><%= item %></li>
            <% }); %>
          <% } %>
        </ul>
      </section>

      <section class="chat-sidebar-group">
        <h3>Secrets Kept</h3>
        <ul class="chat-sidebar-list" data-chat-list="secretsKept">
          <% if (sanitizeSidebarItems(bootstrapChatBible?.knowledgeNow?.secretsKept).length === 0) { %>
            <li class="chat-sidebar-list__empty">No secrets currently kept.</li>
          <% } else { %>
            <% sanitizeSidebarItems(bootstrapChatBible?.knowledgeNow?.secretsKept).forEach(function(item) { %>
              <li><%= item %></li>
            <% }); %>
          <% } %>
        </ul>
      </section>

      <section class="chat-sidebar-group">
        <h3>Knowledge Boundaries</h3>
        <ul class="chat-sidebar-list" data-chat-list="knowledgeBoundaries">
          <% if (sanitizeSidebarItems(bootstrapChatBible?.knowledgeNow?.knowledgeBoundaries).length === 0) { %>
            <li class="chat-sidebar-list__empty">No active knowledge boundaries.</li>
          <% } else { %>
            <% sanitizeSidebarItems(bootstrapChatBible?.knowledgeNow?.knowledgeBoundaries).forEach(function(item) { %>
              <li><%= item %></li>
            <% }); %>
          <% } %>
        </ul>
      </section>
    </div>
  </details>

  <details
    class="chat-accordion chat-sidebar__section"
    id="chat-conversation-state"
    data-chat-section="conversation"
    open
  >
    <summary class="chat-accordion-summary">
      <span class="chat-accordion-summary__title">Conversation</span>
      <span class="chat-accordion-summary__meta">
        <span class="chat-summary-chip" data-chat-field="conversationSummary"><%= conversationSummary %></span>
      </span>
    </summary>

    <div class="chat-accordion-content">
      <dl class="chat-sidebar-details chat-sidebar-details--compact">
        <div class="chat-sidebar-details__row">
          <dt>Last Turn Pressure</dt>
          <dd><span data-chat-field="lastTurnPressure"><%= normalizeSidebarText(bootstrapChatBible?.conversationNow?.lastTurnPressure, 'No active last-turn pressure.') %></span></dd>
        </div>
        <div class="chat-sidebar-details__row">
          <dt>Rolling Summary</dt>
          <dd><span data-chat-field="conversationRollingSummary"><%= normalizeSidebarText(bootstrapRollingSummary?.compressedSummary, 'No rolling summary available.') %></span></dd>
        </div>
      </dl>

      <section class="chat-sidebar-group">
        <h3>Active Threads</h3>
        <ul class="chat-sidebar-list" data-chat-list="activeThreads">
          <% if (sanitizeSidebarItems(bootstrapChatBible?.conversationNow?.activeThreads).length === 0) { %>
            <li class="chat-sidebar-list__empty">No active threads.</li>
          <% } else { %>
            <% sanitizeSidebarItems(bootstrapChatBible?.conversationNow?.activeThreads).forEach(function(item) { %>
              <li><%= item %></li>
            <% }); %>
          <% } %>
        </ul>
      </section>

      <section class="chat-sidebar-group">
        <h3>Commitments</h3>
        <ul class="chat-sidebar-list" data-chat-list="commitments">
          <% if (sanitizeSidebarItems(bootstrapChatBible?.conversationNow?.commitments).length === 0) { %>
            <li class="chat-sidebar-list__empty">No commitments tracked.</li>
          <% } else { %>
            <% sanitizeSidebarItems(bootstrapChatBible?.conversationNow?.commitments).forEach(function(item) { %>
              <li><%= item %></li>
            <% }); %>
          <% } %>
        </ul>
      </section>

      <section class="chat-sidebar-group">
        <h3>Sensitive Topics</h3>
        <ul class="chat-sidebar-list" data-chat-list="sensitiveTopics">
          <% if (sanitizeSidebarItems(bootstrapChatBible?.conversationNow?.sensitiveTopics).length === 0) { %>
            <li class="chat-sidebar-list__empty">No sensitive topics noted.</li>
          <% } else { %>
            <% sanitizeSidebarItems(bootstrapChatBible?.conversationNow?.sensitiveTopics).forEach(function(item) { %>
              <li><%= item %></li>
            <% }); %>
          <% } %>
        </ul>
      </section>
    </div>
  </details>

  <details
    class="chat-accordion chat-sidebar__section"
    id="chat-guardrails"
    data-chat-section="guardrails"
    open
  >
    <summary class="chat-accordion-summary">
      <span class="chat-accordion-summary__title">Guardrails &amp; Constraints</span>
      <span class="chat-accordion-summary__meta">
        <span class="chat-summary-chip" data-chat-field="guardrailsSummary"><%= guardrailsSummary %></span>
      </span>
    </summary>

    <div class="chat-accordion-content">
      <section class="chat-sidebar-group">
        <h3>Continuity Guardrails</h3>
        <ul class="chat-sidebar-list" data-chat-list="continuityGuardrails">
          <% if (sanitizeSidebarItems(bootstrapChatBible?.continuityGuardrails).length === 0) { %>
            <li class="chat-sidebar-list__empty">No continuity guardrails.</li>
          <% } else { %>
            <% sanitizeSidebarItems(bootstrapChatBible?.continuityGuardrails).forEach(function(item) { %>
              <li><%= item %></li>
            <% }); %>
          <% } %>
        </ul>
      </section>

      <section class="chat-sidebar-group">
        <h3>Response Constraints</h3>
        <ul class="chat-sidebar-list" data-chat-list="responseConstraints">
          <% if (sanitizeSidebarItems(bootstrapChatBible?.responseConstraints).length === 0) { %>
            <li class="chat-sidebar-list__empty">No response constraints.</li>
          <% } else { %>
            <% sanitizeSidebarItems(bootstrapChatBible?.responseConstraints).forEach(function(item) { %>
              <li><%= item %></li>
            <% }); %>
          <% } %>
        </ul>
      </section>
    </div>
  </details>

  <section class="chat-sidebar__section" id="chat-lead-in-context">
    <h3>Lead-In</h3>
    <p><%= session.leadInContext.leadInSummary %></p>
    <% if (session.leadInContext.recentEvents.length > 0) { %>
      <ul id="chat-recent-events">
        <% session.leadInContext.recentEvents.forEach(function(eventSummary) { %>
          <li><%= eventSummary %></li>
        <% }); %>
      </ul>
    <% } %>
    <p><strong>Why now:</strong> <span data-chat-field="whyNow"><%= session.leadInContext.whyNow %></span></p>
  </section>
</aside>
